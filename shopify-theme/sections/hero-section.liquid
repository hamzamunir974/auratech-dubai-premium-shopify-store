<section class="hero-section section-padding">
  <div class="hero-section__inner page-width">
    <div class="hero-section__content">
      <p class="section-kicker">{{ section.settings.kicker }}</p>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.text }}</p>
      <div class="hero-section__actions">
        <a class="button button--primary" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">{{ section.settings.primary_label }}</a>
        <a class="button button--secondary" href="{{ section.settings.secondary_link | default: routes.all_products_collection_url }}">{{ section.settings.secondary_label }}</a>
      </div>
      <div class="hero-section__proof" aria-label="Store highlights">
        <span>{{ section.settings.proof_one }}</span>
        <span>{{ section.settings.proof_two }}</span>
        <span>{{ section.settings.proof_three }}</span>
      </div>
    </div>

    <div class="hero-showcase" aria-label="Featured tech products">
      <article class="hero-product hero-product--large">
        {% if section.settings.main_image != blank %}
          <img src="{{ section.settings.main_image | image_url: width: 900 }}" alt="{{ section.settings.main_image.alt | escape }}" width="900" height="900">
        {% else %}
          <img src="{{ 'solar-powerbank.png' | asset_url }}" alt="Solar power bank charging multiple phones" width="900" height="900">
        {% endif %}
        <div>
          <span>{{ section.settings.main_eyebrow }}</span>
          <strong>{{ section.settings.main_product }}</strong>
        </div>
      </article>
      <article class="hero-product hero-product--small">
        {% if section.settings.side_image_one != blank %}
          <img src="{{ section.settings.side_image_one | image_url: width: 500 }}" alt="{{ section.settings.side_image_one.alt | escape }}" width="500" height="500">
        {% else %}
          <img src="{{ 'gold-smartwatch.png' | asset_url }}" alt="Gold smartwatch with metal strap" width="500" height="500">
        {% endif %}
        <strong>{{ section.settings.side_title_one }}</strong>
      </article>
      <article class="hero-product hero-product--small">
        {% if section.settings.side_image_two != blank %}
          <img src="{{ section.settings.side_image_two | image_url: width: 500 }}" alt="{{ section.settings.side_image_two.alt | escape }}" width="500" height="500">
        {% else %}
          <img src="{{ 'red-headphones.png' | asset_url }}" alt="Red wireless headphones" width="500" height="500">
        {% endif %}
        <strong>{{ section.settings.side_title_two }}</strong>
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero section",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Premium UAE electronics" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Dubai's Premium Destination for Tech" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Discover smart accessories, audio essentials, charging solutions, and everyday gadgets selected for modern UAE lifestyles." },
    { "type": "text", "id": "primary_label", "label": "Primary button label", "default": "Shop Now" },
    { "type": "url", "id": "primary_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "Explore Deals" },
    { "type": "url", "id": "secondary_link", "label": "Secondary button link" },
    { "type": "text", "id": "proof_one", "label": "Proof point 1", "default": "Fast UAE dispatch" },
    { "type": "text", "id": "proof_two", "label": "Proof point 2", "default": "AED pricing" },
    { "type": "text", "id": "proof_three", "label": "Proof point 3", "default": "Secure payments" },
    { "type": "image_picker", "id": "main_image", "label": "Main image" },
    { "type": "text", "id": "main_eyebrow", "label": "Main product eyebrow", "default": "Power essentials" },
    { "type": "text", "id": "main_product", "label": "Main product title", "default": "Solar Power Bank" },
    { "type": "image_picker", "id": "side_image_one", "label": "Side image 1" },
    { "type": "text", "id": "side_title_one", "label": "Side title 1", "default": "Smartwatches" },
    { "type": "image_picker", "id": "side_image_two", "label": "Side image 2" },
    { "type": "text", "id": "side_title_two", "label": "Side title 2", "default": "Audio Picks" }
  ],
  "presets": [
    { "name": "Hero section" }
  ]
}
{% endschema %}
