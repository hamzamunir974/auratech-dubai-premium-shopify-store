<footer class="site-footer">
  <div class="site-footer__inner page-width">
    <div class="site-footer__brand">
      <a class="brand-logo brand-logo--footer" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        <img class="brand-logo__full" src="{{ 'auratech-logo-secondary.png' | asset_url }}" alt="{{ shop.name | escape }}" width="430" height="180">
      </a>
      <p>{{ section.settings.description }}</p>
      <div class="footer-socials" aria-label="Social links">
        <a href="{{ section.settings.instagram_url }}" aria-label="Instagram">IG</a>
        <a href="{{ section.settings.tiktok_url }}" aria-label="TikTok">TT</a>
        <a href="{{ section.settings.facebook_url }}" aria-label="Facebook">FB</a>
      </div>
    </div>

    <div class="footer-links">
      <h3>Shop</h3>
      {% if section.settings.shop_menu.links.size > 0 %}
        {% for link in section.settings.shop_menu.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      {% else %}
        <a href="/collections/mobiles">Mobiles</a>
        <a href="/collections/laptops">Laptops</a>
        <a href="/collections/audio">Audio</a>
        <a href="/collections/smartwatches">Smartwatches</a>
        <a href="/collections/accessories">Accessories</a>
      {% endif %}
    </div>

    <div class="footer-links">
      <h3>Customer Care</h3>
      {% if section.settings.care_menu.links.size > 0 %}
        {% for link in section.settings.care_menu.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      {% else %}
        <a href="/pages/contact">Contact Us</a>
        <a href="/pages/delivery-information">Delivery Information</a>
        <a href="/pages/returns">Returns</a>
        <a href="/pages/warranty-support">Warranty Support</a>
        <a href="/pages/faqs">FAQs</a>
      {% endif %}
    </div>

    <div class="footer-trust">
      <h3>{{ section.settings.trust_heading }}</h3>
      <p>{{ section.settings.trust_text }}</p>
      <div class="payment-icons" aria-label="Payment methods">
        <span>Visa</span>
        <span>MC</span>
        <span>Apple Pay</span>
        <span>COD</span>
      </div>
    </div>
  </div>
  <div class="site-footer__bottom page-width">
    <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>
    <span>{{ section.settings.bottom_text }}</span>
  </div>
</footer>

{% schema %}
{
  "name": "Site footer",
  "settings": [
    { "type": "textarea", "id": "description", "label": "Brand description", "default": "Premium UAE tech essentials for mobile, audio, power, smart accessories, and modern everyday setups." },
    { "type": "link_list", "id": "shop_menu", "label": "Shop menu" },
    { "type": "link_list", "id": "care_menu", "label": "Customer care menu" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "tiktok_url", "label": "TikTok URL" },
    { "type": "url", "id": "facebook_url", "label": "Facebook URL" },
    { "type": "text", "id": "trust_heading", "label": "Trust heading", "default": "Secure Shopping" },
    { "type": "textarea", "id": "trust_text", "label": "Trust text", "default": "UAE delivery, AED pricing, secure checkout, and responsive customer support." },
    { "type": "text", "id": "bottom_text", "label": "Bottom text", "default": "Built as a Shopify-ready storefront." }
  ]
}
{% endschema %}
