<footer class="site-footer">
  <div class="site-footer__inner page-width">
    <div class="site-footer__brand">
      <a class="brand-logo brand-logo--footer" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        <img class="brand-logo__full" src="{{ 'auratech-logo-secondary.png' | asset_url }}" alt="{{ shop.name | escape }}" width="430" height="180">
      </a>
      <p>{{ section.settings.description }}</p>
      {% if section.settings.instagram_url != blank or section.settings.tiktok_url != blank or section.settings.facebook_url != blank %}
        <div class="footer-socials" aria-label="Social links">
          {% if section.settings.instagram_url != blank %}<a href="{{ section.settings.instagram_url }}" aria-label="Instagram">IG</a>{% endif %}
          {% if section.settings.tiktok_url != blank %}<a href="{{ section.settings.tiktok_url }}" aria-label="TikTok">TT</a>{% endif %}
          {% if section.settings.facebook_url != blank %}<a href="{{ section.settings.facebook_url }}" aria-label="Facebook">FB</a>{% endif %}
        </div>
      {% endif %}
    </div>

    <div class="footer-links">
      <h3>Shop</h3>
      {% if section.settings.shop_menu.links.size > 0 %}
        {% for link in section.settings.shop_menu.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      {% else %}
        <a href="{{ collections['mobiles'].url | default: routes.all_products_collection_url }}">Mobiles</a>
        <a href="{{ collections['laptops'].url | default: routes.all_products_collection_url }}">Laptops</a>
        <a href="{{ collections['audio'].url | default: routes.all_products_collection_url }}">Audio</a>
        <a href="{{ collections['smartwatches'].url | default: routes.all_products_collection_url }}">Smartwatches</a>
        <a href="{{ collections['accessories'].url | default: routes.all_products_collection_url }}">Accessories</a>
      {% endif %}
    </div>

    <div class="footer-links">
      <h3>Customer Care</h3>
      {% if section.settings.care_menu.links.size > 0 %}
        {% for link in section.settings.care_menu.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      {% else %}        {% if shop.email != blank %}<a href="mailto:{{ shop.email }}">Contact Us</a>{% endif %}
        {% if shop.shipping_policy != blank %}<a href="{{ shop.shipping_policy.url }}">Delivery Information</a>{% endif %}
        {% if shop.refund_policy != blank %}<a href="{{ shop.refund_policy.url }}">Returns</a>{% endif %}
        {% if shop.terms_of_service != blank %}<a href="{{ shop.terms_of_service.url }}">Terms of Service</a>{% endif %}
        {% if shop.privacy_policy != blank %}<a href="{{ shop.privacy_policy.url }}">Privacy Policy</a>{% endif %}
      {% endif %}
    </div>

    <div class="footer-trust">
      <h3>{{ section.settings.trust_heading }}</h3>
      <p>{{ section.settings.trust_text }}</p>
      <div class="payment-icons" aria-label="Payment methods">
        {% if shop.enabled_payment_types.size > 0 %}
          {% for type in shop.enabled_payment_types %}
            <span class="payment-icon">{{ type | payment_type_svg_tag }}</span>
          {% endfor %}
        {% else %}
          <span>Secure checkout</span>
        {% endif %}
      </div>
    </div>
  </div>
  <div class="site-footer__bottom page-width">
    <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>
    <span>{{ section.settings.bottom_text }}</span>
  </div>
</footer>

{% schema %}
{
  "name": "Site footer",
  "settings": [
    { "type": "textarea", "id": "description", "label": "Brand description", "default": "Premium UAE tech essentials for mobile, audio, power, smart accessories, and modern everyday setups." },
    { "type": "link_list", "id": "shop_menu", "label": "Shop menu" },
    { "type": "link_list", "id": "care_menu", "label": "Customer care menu" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "tiktok_url", "label": "TikTok URL" },
    { "type": "url", "id": "facebook_url", "label": "Facebook URL" },
    { "type": "text", "id": "trust_heading", "label": "Trust heading", "default": "Secure Shopping" },
    { "type": "textarea", "id": "trust_text", "label": "Trust text", "default": "UAE delivery, AED pricing, secure checkout, and responsive customer support." },
    { "type": "text", "id": "bottom_text", "label": "Bottom text", "default": "Built as a Shopify-ready storefront." }
  ]
}
{% endschema %}
