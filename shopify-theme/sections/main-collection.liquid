<section class="main-collection section-padding">
  <div class="section-header section-header--split page-width">
    <div>
      <p class="section-kicker">{{ collection.products_count }} products</p>
      <h1>{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <div class="main-collection__description">{{ collection.description }}</div>
      {% endif %}
    </div>
  </div>

  {% paginate collection.products by 12 %}
    <div class="product-grid page-width">
      {% for product in collection.products %}
        {% render 'product-card', product: product %}
      {% else %}
        <div class="empty-state product-grid__empty">
          <h2>No products found</h2>
          <p>Add products to this collection and publish them to the Online Store sales channel.</p>
          <a class="button button--primary" href="{{ routes.all_products_collection_url }}">View All Products</a>
        </div>
      {% endfor %}
    </div>

    {% if paginate.pages > 1 %}
      <nav class="pagination page-width" role="navigation" aria-label="Pagination">
        {% if paginate.previous %}
          <a class="pagination__link" href="{{ paginate.previous.url }}">Previous</a>
        {% else %}
          <span class="pagination__link is-disabled">Previous</span>
        {% endif %}
        <span class="pagination__status">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
        {% if paginate.next %}
          <a class="pagination__link" href="{{ paginate.next.url }}">Next</a>
        {% else %}
          <span class="pagination__link is-disabled">Next</span>
        {% endif %}
      </nav>
    {% endif %}
  {% endpaginate %}
</section>

{% schema %}
{
  "name": "Main collection"
}
{% endschema %}