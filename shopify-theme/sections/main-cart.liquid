<section class="main-cart section-padding">
  <div class="page-width">
    <div class="section-header section-header--split">
      <div>
        <p class="section-kicker">Secure checkout</p>
        <h1>Your Cart</h1>
      </div>
      <a class="text-link" href="{{ routes.all_products_collection_url }}">Continue shopping</a>
    </div>

    {% if cart.item_count > 0 %}
      <form action="{{ routes.cart_url }}" method="post" class="cart-panel">
        {% for item in cart.items %}
          <article class="cart-item">
            <a href="{{ item.url }}">
              {% if item.image %}
                <img src="{{ item.image | image_url: width: 240 }}" alt="{{ item.image.alt | default: item.product.title | escape }}" width="240" height="240">
              {% endif %}
            </a>
            <div>
              <h3><a href="{{ item.url }}">{{ item.product.title }}</a></h3>
              <p>{{ item.variant.title }}</p>
              <strong>{{ item.final_line_price | money }}</strong>
            </div>
            <label>
              Quantity
              <input type="number" name="updates[]" value="{{ item.quantity }}" min="0">
            </label>
          </article>
        {% endfor %}
        <div class="cart-summary">
          <span>Subtotal</span>
          <strong>{{ cart.total_price | money }}</strong>
          <button class="button button--secondary" type="submit" name="update">Update Cart</button>
          <button class="button button--primary" type="submit" name="checkout">Checkout</button>
        </div>
      </form>
    {% else %}
      <div class="empty-state">
        <h2>Your cart is empty</h2>
        <p>Explore AuraTech Dubai products and add your favorite tech essentials.</p>
        <a class="button button--primary" href="{{ routes.all_products_collection_url }}">Shop Now</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main cart"
}
{% endschema %}
