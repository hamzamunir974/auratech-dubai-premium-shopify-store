<header class="site-header" data-header>
  <div class="site-header__inner page-width">
    <a class="brand-logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      <img class="brand-logo__full" src="{{ 'auratech-logo-secondary.png' | asset_url }}" alt="{{ shop.name | escape }}" width="430" height="180">
      <img class="brand-logo__icon" src="{{ 'auratech-logo-icon.png' | asset_url }}" alt="" aria-hidden="true" width="210" height="175">
    </a>

    <nav class="desktop-nav" aria-label="Main navigation">
      {% if section.settings.menu.links.size > 0 %}
        {% for link in section.settings.menu.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      {% else %}
        <a href="/collections/mobiles">Mobiles</a>
        <a href="/collections/laptops">Laptops</a>
        <a href="/collections/audio">Audio</a>
        <a href="/collections/smartwatches">Smartwatches</a>
        <a href="/collections/accessories">Accessories</a>
        <a href="/collections/deals">Deals</a>
      {% endif %}
    </nav>

    <form class="header-search" action="{{ routes.search_url }}" method="get" role="search">
      <label class="visually-hidden" for="site-search">Search products</label>
      <input id="site-search" type="search" name="q" placeholder="Search tech..." value="{{ search.terms | escape }}">
      <button type="submit" aria-label="Search">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M10.8 4.5a6.3 6.3 0 1 1 0 12.6 6.3 6.3 0 0 1 0-12.6Zm0 1.8a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Zm5.1 9.2 3.6 3.6-1.3 1.3-3.6-3.6 1.3-1.3Z" />
        </svg>
      </button>
    </form>

    <div class="header-actions" aria-label="Account and cart">
      <a class="icon-button" href="{{ routes.account_login_url }}" aria-label="Account">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 12.2a4.1 4.1 0 1 1 0-8.2 4.1 4.1 0 0 1 0 8.2Zm0-1.8a2.3 2.3 0 1 0 0-4.6 2.3 2.3 0 0 0 0 4.6ZM4.8 20c.7-3.6 3.4-5.6 7.2-5.6s6.5 2 7.2 5.6h-1.9c-.6-2.5-2.4-3.8-5.3-3.8S7.3 17.5 6.7 20H4.8Z" />
        </svg>
      </a>
      <a class="icon-button" href="/pages/wishlist" aria-label="Wishlist">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 20.6 10.9 19C6.6 15.1 4 12.7 4 9.4A4.5 4.5 0 0 1 8.6 5c1.4 0 2.7.6 3.4 1.6A4.2 4.2 0 0 1 15.4 5 4.5 4.5 0 0 1 20 9.4c0 3.3-2.6 5.7-6.9 9.6L12 20.6Zm-2.7-3.1.1.1 2.6 2.4 2.6-2.4.1-.1c4-3.6 5.5-5.2 5.5-8.1a2.7 2.7 0 0 0-2.8-2.7c-1.3 0-2.5.8-3 2h-1.7c-.5-1.2-1.7-2-3-2A2.7 2.7 0 0 0 5.8 9.4c0 2.9 1.5 4.5 5.5 8.1Z" />
        </svg>
      </a>
      <a class="icon-button icon-button--cart" href="{{ routes.cart_url }}" aria-label="Cart">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7 18.5a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3Zm10 0a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM3.5 4H6l2.2 10.8h8.5l2-7.1H8.4L8 5.9h13.1l-3 10.7H6.7L4.5 5.8h-1V4Z" />
        </svg>
        <span>{{ cart.item_count }}</span>
      </a>
      <button class="menu-toggle" type="button" aria-label="Open menu" aria-expanded="false" data-menu-toggle>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div class="mobile-menu" data-mobile-menu>
    <nav class="mobile-menu__nav" aria-label="Mobile navigation">
      {% if section.settings.menu.links.size > 0 %}
        {% for link in section.settings.menu.links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      {% else %}
        <a href="/collections/mobiles">Mobiles</a>
        <a href="/collections/laptops">Laptops</a>
        <a href="/collections/audio">Audio</a>
        <a href="/collections/smartwatches">Smartwatches</a>
        <a href="/collections/accessories">Accessories</a>
        <a href="/collections/deals">Deals</a>
      {% endif %}
    </nav>
    <form class="mobile-search" action="{{ routes.search_url }}" method="get" role="search">
      <label class="visually-hidden" for="mobile-site-search">Search products</label>
      <input id="mobile-site-search" type="search" name="q" placeholder="Search AuraTech Dubai" value="{{ search.terms | escape }}">
      <button class="button button--primary" type="submit">Search</button>
    </form>
  </div>
</header>

{% schema %}
{
  "name": "Site header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
