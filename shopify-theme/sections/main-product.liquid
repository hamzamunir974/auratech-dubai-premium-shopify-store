<section class="main-product section-padding">
  <div class="main-product__inner page-width">
    <div class="main-product__media">
      {% if product.featured_image %}
        <img
          src="{{ product.featured_image | image_url: width: 1000 }}"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          width="1000"
          height="1000"
        >
      {% else %}
        <img src="{{ 'solar-powerbank.png' | asset_url }}" alt="{{ product.title | escape }}" width="1000" height="1000">
      {% endif %}
    </div>

    <div class="main-product__details">
      <p class="section-kicker">{{ product.vendor | default: 'AuraTech Dubai' }}</p>
      <h1>{{ product.title }}</h1>
      <div class="rating">***** <span>4.7</span></div>
      <div class="main-product__price">
        <strong>{{ product.price | money }}</strong>
        {% if product.compare_at_price > product.price %}
          <span>{{ product.compare_at_price | money }}</span>
        {% endif %}
      </div>
      <div class="main-product__description">
        {{ product.description }}
      </div>

      {% form 'product', product, class: 'main-product__form' %}
        {% if product.variants.size > 1 %}
          <label for="ProductSelect-{{ section.id }}">Choose option</label>
          <select id="ProductSelect-{{ section.id }}" name="id">
            {% for variant in product.variants %}
              <option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>
                {{ variant.title }} - {{ variant.price | money }}
              </option>
            {% endfor %}
          </select>
        {% else %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        {% endif %}
        <button class="button button--primary" type="submit" {% unless product.available %}disabled{% endunless %}>
          {% if product.available %}Add to Cart{% else %}Sold Out{% endif %}
        </button>
      {% endform %}
      {% for block in section.blocks %}
        {% case block.type %}
          {% when '@app' %}
            <div class="main-product__app-block" {{ block.shopify_attributes }}>
              {% render block %}
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "blocks": [
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
