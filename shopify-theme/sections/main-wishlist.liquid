<section class="main-wishlist section-padding">
  <div class="page-width">
    <div class="section-header section-header--split">
      <div>
        <p class="section-kicker">Saved products</p>
        <h1>{{ page.title | default: 'Wishlist' }}</h1>
      </div>
      <a class="text-link" href="{{ routes.all_products_collection_url }}">Continue shopping</a>
    </div>

    <div class="empty-state" data-wishlist-empty>
      <h2>Your wishlist is empty</h2>
      <p>Save products using the wishlist button and they will appear here on this device.</p>
      <a class="button button--primary" href="{{ routes.all_products_collection_url }}">Shop Products</a>
    </div>

    <div class="product-grid wishlist-grid" data-wishlist-grid hidden></div>
  </div>
</section>

{% schema %}
{
  "name": "Main wishlist"
}
{% endschema %}